{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Member"] },
        "picUrl": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing multiple tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed", "On Hold"] },
        "progress": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A specific task within a project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed", "Overdue"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "assigneeId": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "projectId"]
    },
    "Team": {
      "title": "Team",
      "description": "A group of users collaborating on projects",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "projectIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Storage for projects"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Storage for tasks"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Storage for teams"
    }
  }
}
